        "$slot",
        "diagnose"
      ],
      "symbol": "tile_drive_h_diagnose",
      "header": "tile_drive_h.h",
      "category": "tile",
      "description": "Run actuator diagnostics.",
      "params": [],
      "returns": "uint8_t",
      "dsl_returns": "bool",
      "receiver": "tile_t*"
    },
    {
      "qname": [
        "$slot",
        "calibrate"
      ],
      "symbol": "tile_drive_h_calibrate",
      "header": "tile_drive_h.h",
      "category": "tile",
      "description": "Run auto-calibration for the connected actuator.",
      "params": [],
      "returns": "uint8_t",
      "dsl_returns": "bool",
      "receiver": "tile_t*"
    },
    {
      "qname": [
        "$slot",
        "get_vbat_mv"
      ],
      "symbol": "tile_drive_h_get_vbat_mv",
      "header": "tile_drive_h.h",
      "category": "tile",
      "description": "Read supply voltage in millivolts.",
      "params": [],
      "returns": "uint16_t",
      "dsl_returns": "int",
      "receiver": "tile_t*"
    },
    {
      "qname": [
        "$slot",
        "get_resonance_hz"
      ],
      "symbol": "tile_drive_h_get_resonance_hz",
      "header": "tile_drive_h.h",
      "category": "tile",
      "description": "Read LRA resonant frequency in Hz.",
      "params": [],
      "returns": "uint16_t",
      "dsl_returns": "int",
      "receiver": "tile_t*"
    },
    {
      "qname": [
        "$slot",
        "standby"
      ],
      "symbol": "tile_drive_h_standby",
      "header": "tile_drive_h.h",
      "category": "tile",
      "description": "Enter low-power standby.",
      "params": [],
      "returns": "void",
      "receiver": "tile_t*"
    },
    {
