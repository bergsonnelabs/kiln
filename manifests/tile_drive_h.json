{
  "schema": "tessera-manifest/v1",
  "source": "cores@ad1485f",
  "tile": "Drive.H",
  "palette": {
    "label": "Drive.H",
    "icon": "≋"
  },
  "driver": {
    "prefix": "tile_drive_h",
    "header": "tile_drive_h.h",
    "version": "1.0.0"
  },
  "handle": {
    "type": "tile_t",
    "init": "tile_drive_h_init"
  },
  "hosts": [
    {
      "qname": [
        "$slot",
        "play"
      ],
      "symbol": "tile_drive_h_play",
      "header": "tile_drive_h.h",
      "category": "tile",
      "description": "Play a waveform effect from the built-in library.",
      "params": [
        {
          "name": "index",
          "type": "int",
          "range": [
            1,
            123
          ],
          "description": "Library effect index (see datasheet)."
        },
        {
          "name": "repeats",
          "type": "int",
          "range": [
            1,
            20
          ],
          "description": "Number of times to play (1 = once)."
        }
      ],
      "returns": "void",
      "receiver": "tile_t*"
    },
    {
      "qname": [
        "$slot",
        "play_sequence"
      ],
      "symbol": "tile_drive_h_play_sequence",
      "header": "tile_drive_h.h",
      "category": "tile",
      "description": "Play a sequence of up to 8 waveform effects.",
      "params": [
        {
          "name": "effects",
          "type": "int[8]",
          "description": "Array of effect indices (1-123, 0 = stop)"
        }
      ],
      "returns": "void",
      "c_in_buffer": {
        "name": "effects",
        "type": "uint8_t",
        "length_param": "count",
        "length": 8
      },
      "receiver": "tile_t*"
    },
    {
      "qname": [
        "$slot",
        "load_sequence"
      ],
      "symbol": "tile_drive_h_load_sequence",
      "header": "tile_drive_h.h",
      "category": "tile",
      "description": "Load effects into the waveform sequencer without triggering.",
      "params": [
        {
          "name": "effects",
          "type": "int[8]",
          "description": "Array of effect indices (1-123, 0 = stop)"
        }
      ],
      "returns": "void",
      "c_in_buffer": {
        "name": "effects",
        "type": "uint8_t",
        "length_param": "count",
        "length": 8
      },
      "receiver": "tile_t*"
    },
    {
      "qname": [
        "$slot",
        "set_trigger"
      ],
      "symbol": "tile_drive_h_set_trigger",
      "header": "tile_drive_h.h",
      "category": "tile",
      "description": "Set the trigger mode.",
      "params": [
        {
          "name": "mode",
          "type": "int",
          "description": "One of DRIVE_H_TRIG_INTERNAL, DRIVE_H_TRIG_EDGE,"
        }
      ],
      "returns": "void",
      "receiver": "tile_t*"
    },
    {
      "qname": [
        "$slot",
        "is_playing"
      ],
      "symbol": "tile_drive_h_is_playing",
      "header": "tile_drive_h.h",
      "category": "tile",
      "description": "Check whether an effect or sequence is still playing.",
      "params": [],
      "returns": "uint8_t",
      "dsl_returns": "bool",
      "receiver": "tile_t*"
    },
    {
      "qname": [
        "$slot",
        "stop"
      ],
      "symbol": "tile_drive_h_stop",
      "header": "tile_drive_h.h",
      "category": "tile",
      "description": "Stop any currently playing effect.",
      "params": [],
      "returns": "void",
      "receiver": "tile_t*"
    },
    {
      "qname": [
        "$slot",
        "rtp_start"
      ],
      "symbol": "tile_drive_h_rtp_start",
      "header": "tile_drive_h.h",
      "category": "tile",
      "description": "Enter RTP (Real-Time Playback) mode.",
      "params": [],
      "returns": "void",
      "receiver": "tile_t*"
    },
    {
      "qname": [
        "$slot",
        "rtp_write"
      ],
      "symbol": "tile_drive_h_rtp_write",
      "header": "tile_drive_h.h",
      "category": "tile",
      "description": "Write an amplitude value in RTP mode.",
      "params": [
        {
          "name": "amplitude",
          "type": "int",
          "range": [
            0,
            127
          ],
          "description": "Amplitude (0 = off, 127 = max)."
        }
      ],
      "returns": "void",
      "receiver": "tile_t*"
    },
    {
      "qname": [
        "$slot",
        "rtp_stop"
      ],
      "symbol": "tile_drive_h_rtp_stop",
      "header": "tile_drive_h.h",
      "category": "tile",
      "description": "Exit RTP mode and return to internal trigger mode.",
      "params": [],
      "returns": "void",
      "receiver": "tile_t*"
    },
    {
      "qname": [
        "$slot",
        "get_status"
      ],
      "symbol": "tile_drive_h_get_status",
